Make the adbmdns crate build cross-platform (android + windows/macos hosts).

Upstream's adbmdns is a host-only tool wired for target_os = linux/macos/windows
with manifest assumptions that don't hold for our cross builds:

  1. netwatch.rs: route target_os="android" to the linux (netlink) backend, so the
     bionic build resolves monitor_network_changes_native().
  2. netwatch_linux.rs: the libc crate doesn't export RTMGRP_LINK for android;
     inline its UAPI value (1) — the netlink multicast-group bitmask.
  3. Cargo.toml: nix (used only by netwatch_linux) was an unconditional dependency,
     but nix is unix-only and fails to build for windows. Make it target-specific
     (linux/android) and add the "net" feature it needs for net::if_.
  4. Cargo.toml: windows-sys was likewise unconditional and fails to build (WSADATA/
     SERVENT) on non-windows targets. Gate it under cfg(windows).

The crate's own per-OS code (netwatch_{linux,darwin,windows}) is already cfg-gated;
only the manifest and the android specifics needed fixing. BSD has no netwatch
backend at all and uses the openscreen fallback (see scripts/build.sh).
--- a/src/adb/client/adbmdns/netwatch.rs
+++ b/src/adb/client/adbmdns/netwatch.rs
@@ -20,7 +20,7 @@
 #[cfg(target_os = "macos")]
 pub mod netwatch_darwin;

-#[cfg(target_os = "linux")]
+#[cfg(any(target_os = "linux", target_os = "android"))]
 pub mod netwatch_linux;

 #[cfg(target_os = "windows")]
@@ -29,7 +29,7 @@
 #[cfg(target_os = "macos")]
 pub use netwatch_darwin::monitor_network_changes_native;

-#[cfg(target_os = "linux")]
+#[cfg(any(target_os = "linux", target_os = "android"))]
 pub use netwatch_linux::monitor_network_changes_native;

 type NetworkMonitorCallback = Box<dyn Fn() + Send + Sync + 'static>;
--- a/src/adb/client/adbmdns/netwatch/netwatch_linux.rs
+++ b/src/adb/client/adbmdns/netwatch/netwatch_linux.rs
@@ -168,7 +168,7 @@
     .context("Failed to open NetLink socket")?;

     log::debug!("Creating NetlinkAddr");
-    let sa = NetlinkAddr::new(0, libc::RTMGRP_LINK as u32);
+    let sa = NetlinkAddr::new(0, 1u32 /* RTMGRP_LINK: not exported by the libc crate for target_os=android */);
     bind(fd.as_raw_fd(), &sa).context("Failed to bind NetLinkAddr")?;

     let mut message_buf = MessageBuffer::default();
--- a/src/adb/client/adbmdns/Cargo.toml
+++ b/src/adb/client/adbmdns/Cargo.toml
@@ -14,11 +14,13 @@
 zerocopy = { version = "0.8.26", features = ["derive"] }
 libc = "0.2.174"
 anyhow = "1.0.99"
-nix = { version = "0.29.0", features = ["socket", "uio"] }
 if-addrs = "0.14.0"
 mio = { version = "1.1.0", features = ["net", "os-poll"] }

-[dependencies.windows-sys]
+[target.'cfg(any(target_os = "linux", target_os = "android"))'.dependencies]
+nix = { version = "0.29.0", features = ["socket", "uio", "net"] }
+
+[target.'cfg(windows)'.dependencies.windows-sys]
 version = "0.61.1"
 features = [
     "Win32_Foundation",
