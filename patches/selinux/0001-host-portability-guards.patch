+#if defined(_WIN32) && !defined(HAVE_GETLINE)
+#include <stdlib.h>
+static inline ssize_t getline(char **__lineptr, size_t *__n, FILE *__stream)
+{
+	size_t __pos = 0;
+	int __c;
+	if (*__lineptr == NULL || *__n == 0) {
+		*__n = 256;
+		*__lineptr = (char *)malloc(*__n);
+		if (*__lineptr == NULL) return -1;
+	}
+	while ((__c = fgetc(__stream)) != EOF) {
+		if (__pos + 1 >= *__n) {
+			*__n *= 2;
+			char *__new = (char *)realloc(*__lineptr, *__n);
+			if (__new == NULL) return -1;
+			*__lineptr = __new;
+		}
+		(*__lineptr)[__pos++] = (char)__c;
+		if (__c == '\n') break;
+	}
+	if (__pos == 0) return -1;
+	(*__lineptr)[__pos] = '\0';
