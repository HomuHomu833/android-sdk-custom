+++ b/libselinux/src/context.c
@@ -4,6 +4,17 @@
 #include <stdlib.h>
 #include <errno.h>
 
+/* stpcpy() is a POSIX.1-2008/GNU function mingw doesn't provide; context.c uses
+ * it to assemble a context string. Supply the standard "copy and return the end
+ * pointer" form on Windows only. */
+#if defined(_WIN32)
+static inline char *stpcpy(char *__dst, const char *__src)
+{
+	size_t __len = strlen(__src);
+	return (char *)memcpy(__dst, __src, __len + 1) + __len;
+}
+#endif
+
