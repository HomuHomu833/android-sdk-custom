diff --git a/libselinux/src/init.c b/libselinux/src/init.c
index 439da41..056723d 100644
--- a/libselinux/src/init.c
+++ b/libselinux/src/init.c
@@ -5,10 +5,16 @@
 #include <errno.h>
 #include <ctype.h>
 #include <stdio.h>
+/* The selinuxfs/proc mount probe below is host-inert, and its glibc/musl-only
+ * deps -- <stdio_ext.h> (__fsetlocking), <sys/vfs.h> (statfs) and
+ * <sys/statvfs.h> (statvfs) -- are absent on macOS. Include them only where
+ * they exist; the probe itself is stubbed out for that host below.
+ * (<dlfcn.h> was included but no dl* symbol is used, so it is dropped.) */
+#if !defined(__APPLE__)
 #include <stdio_ext.h>
-#include <dlfcn.h>
 #include <sys/statvfs.h>
 #include <sys/vfs.h>
+#endif
 #include <stdint.h>
 #include <limits.h>
 
@@ -21,6 +27,19 @@ int selinux_page_size = 0;
 
 int has_selinux_config = 0;
 
+#if defined(__APPLE__)
+/* A macOS host has no selinuxfs and no /proc to probe, so there is nothing to
+ * discover: leave selinux_mnt unset. These stubs stand in for the Linux
+ * mount-probe machinery (which needs statfs/statvfs/__fsetlocking). */
+int selinuxfs_exists(void)
+{
+	return 0;
+}
+
+static void init_selinuxmnt(void)
+{
+}
+#else
 /* Verify the mount point for selinux file system has a selinuxfs.
    If the file system:
    * Exist,
@@ -129,6 +148,7 @@ static void init_selinuxmnt(void)
 		fclose(fp);
 	return;
 }
+#endif /* __APPLE__ */
 
 void fini_selinuxmnt(void)
 {
diff --git a/libselinux/src/procattr.c b/libselinux/src/procattr.c
index b7a93a2..329c453 100644
--- a/libselinux/src/procattr.c
+++ b/libselinux/src/procattr.c
@@ -1,4 +1,6 @@
+#if !defined(_WIN32)
 #include <sys/syscall.h>
+#endif
 #include <unistd.h>
 #include <fcntl.h>
 #include <pthread.h>
@@ -27,7 +29,23 @@ static __thread char destructor_initialized;
 
 /* Bionic and glibc >= 2.30 declare gettid() system call wrapper in unistd.h and
  * has a definition for it */
-#ifdef __BIONIC__
+#if defined(_WIN32)
+  /* MinGW has no gettid() / syscall; use the Windows thread ID API. */
+  #include <windows.h>
+  static inline pid_t gettid(void) {
+    return (pid_t)GetCurrentThreadId();
+  }
+  #define HAVE_GETTID 1
+#elif defined(__APPLE__)
+  /* macOS has pthread_threadid_np() instead of gettid(). */
+  #include <pthread.h>
+  static inline pid_t gettid(void) {
+    uint64_t __tid;
+    pthread_threadid_np(NULL, &__tid);
+    return (pid_t)__tid;
+  }
+  #define HAVE_GETTID 1
+#elif defined(__BIONIC__)
   #define HAVE_GETTID 1
 #elif !defined(__GLIBC_PREREQ)
   #define HAVE_GETTID 0
diff --git a/libselinux/src/selinux_config.c b/libselinux/src/selinux_config.c
index 1d8cfb7..ab05fa8 100644
--- a/libselinux/src/selinux_config.c
+++ b/libselinux/src/selinux_config.c
@@ -1,5 +1,12 @@
 #include <stdio.h>
+/* __fsetlocking() (a single-threaded perf hint) and its <stdio_ext.h> are a
+ * glibc/musl extension; macOS lacks both. The hint is irrelevant on a host
+ * build, so make it a no-op there. */
+#if defined(__APPLE__)
+#define __fsetlocking(stream, type) ((void)0)
+#else
 #include <stdio_ext.h>
+#endif
 #include <string.h>
 #include <ctype.h>
 #include <stddef.h>
